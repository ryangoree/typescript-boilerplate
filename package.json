{
  "name": "typescript-boilerplate",
  "version": "0.0.0",
  "description": "TypeScript library boilerplate with tests, docs, builds, and CI/CD.",
  "license": "Apache-2.0",
  "author": "ryan goree (https://github.com/ryangoree)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryangoree/typescript-boilerplate.git"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./testing": {
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      },
      "import": {
        "types": "./dist/testing.d.mts",
        "default": "./dist/testing.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && biome check --diagnostic-level error . ",
    "check:package": "publint",
    "fix": "biome check --diagnostic-level error . --write",
    "fix:unsafe": "npm run fix --unsafe",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "build:docs": "typedoc",
    "dev:docs": "serve ./docs",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "publint": "^0.3.18",
    "serve": "^14.2.6",
    "tsdown": "^0.21.7",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "imports": {
    "#/*": "./dist/*.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.mts"
      ],
      "testing": [
        "./dist/testing.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
